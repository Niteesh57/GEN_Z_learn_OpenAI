.git
.gitignore

# Local dependencies and generated output are rebuilt in Docker.
frontend/node_modules
frontend/dist
backend/venv
backend/__pycache__
**/__pycache__
*.py[cod]

# Secrets must only be supplied at runtime through Docker or Cloud Run.
.env
backend/.env
frontend/.env
frontend/.env.*

# Large local-only files and obsolete source data.
backend/meme
output
*.wav
*.ipynb
test.py
DEVPOST.md
